# --- App ---
APP_ENV=development
LOG_LEVEL=INFO
SERVICE_NAME=llmops-platform

# --- LLM Provider ---
# Default targets OpenAI. To use a free alternative instead, set
# OPENAI_BASE_URL and a matching key/model — no code changes needed:
#   Groq (free):       https://api.groq.com/openai/v1 | model: llama-3.3-70b-versatile
#   OpenRouter (free): https://openrouter.ai/api/v1    | model: deepseek/deepseek-chat:free
OPENAI_API_KEY=your-key-here
OPENAI_BASE_URL=
DEFAULT_MODEL=gpt-4o-mini
MODEL_TIMEOUT_SECONDS=30

# --- PostgreSQL ---
POSTGRES_USER=llmops
POSTGRES_PASSWORD=llmops_pass
POSTGRES_DB=llmops
DATABASE_URL=postgresql+asyncpg://llmops:llmops_pass@postgres:5432/llmops

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_TTL_SECONDS=3600

# --- MLflow ---
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=llmops-platform

# --- Cost tracking ($ per 1K tokens, adjust to provider pricing) ---
COST_PER_1K_PROMPT_TOKENS=0.00015
COST_PER_1K_COMPLETION_TOKENS=0.0006
